"""docs.fastverk.com — the fastverk docs site, built with fastverk_mdbook.

`bazel build //:site` renders the book to `site.tar.gz` (HTML). fastverk_mdbook
(from rules_fastverk) wraps rules_mdbook + stages @brand//mdbook:theme, so the
book is branded by construction. Run the harvesters first (reference + catalog):

    ./tools/harvest-reference.sh && ./tools/harvest-catalog.sh
    bazel build //:site

Layers: guides (src/), per-module API reference (src/reference/, generated by
harvest-reference.sh), module catalog (constellation.md, harvest-catalog.sh).
"""

load("@rules_fastverk//fastverk:defs.bzl", "fastverk_mdbook")

package(default_visibility = ["//visibility:public"])

# srcs defaults to glob(src/**/*.md) — includes the generated src/reference/*.md;
# theme defaults to @brand//mdbook:theme; out defaults to site.tar.gz.
fastverk_mdbook(name = "site")
